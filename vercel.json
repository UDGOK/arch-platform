{
  "version": 2,
  "builds": [
    { "src": "api/server.py", "use": "@vercel/python" },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "api/server.py" },
    { "src": "/healthz",  "dest": "api/server.py" },
    { "src": "/",         "dest": "public/index.html" },
    { "src": "/(.*)",     "dest": "public/$1" }
  ],
  "functions": {
    "api/server.py": {
      "maxDuration": 60
    }
  }
}
